{
  "name": "shouquan-worker",
  "version": "1.0.0",
  "private": true,
  "description": "POS 收银系统 - 授权管理 + 官网（Cloudflare Workers）",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --remote",
    "dev:local": "wrangler dev --persist-to .wrangler/state",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply shouquan-db",
    "db:seed": "wrangler d1 execute shouquan-db --file=./migrations/seed.sql",
    "preview": "wrangler preview"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "wrangler": "^3.114.17"
  }
}
